# FrigoLoco backend - environment variables.
# Copy relevant keys into the repo-root .env (git-ignored). Never commit secrets.
# The backend loads the REPO-ROOT .env (../.env), not this file.

# --- Database (required) ----------------------------------------------------
DB_URL=postgresql+psycopg2://user:password@host:5432/railway

# --- Intelligent Fridges ("Husky") API --------------------------------------
FRIGOLOCO_API_BASE_URL=https://api.intelligentfridges.com/api/v1
FRIGOLOCO_API_USERNAME=your_api_username
FRIGOLOCO_API_PASSWORD=your_api_password
FRIGOLOCO_MERCHANT_NAME=frigoloco

# --- Raw-first ELT archive --------------------------------------------------
RAW_ARCHIVE_DIR=./raw_archive

# --- Historical backfill / sync tuning (optional) ---------------------------
# BACKFILL_FROM=2025-01-01
HUSKY_THROTTLE_RPS=1.0
